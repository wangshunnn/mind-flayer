{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mind Flayer",
  "version": "0.1.0",
  "identifier": "com.soonwang.mindflayer",
  "build": {
    "beforeDevCommand": "pnpm dev:sidecar && pnpm dev:frontend",
    "beforeBuildCommand": "pnpm build:sidecar && pnpm build:frontend",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Mind Flayer",
        "width": 860,
        "height": 710,
        "minWidth": 440,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "decorations": true,
        "hiddenTitle": true,
        "center": true,
        "transparent": true,
        "trafficLightPosition": {
          "x": 24,
          "y": 25
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/16x16.png",
      "icons/16x16@2x.png",
      "icons/32x32.png",
      "icons/32x32@2x.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "externalBin": ["binaries/mind-flayer-sidecar"]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
