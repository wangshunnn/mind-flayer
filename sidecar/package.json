{
  "name": "sidecar",
  "private": true,
  "version": "0.8.1",
  "type": "module",
  "description": "AI SDK sidecar for Mind Flayer",
  "main": "dist/index.js",
  "scripts": {
    "clean:binaries": "rimraf ../src-tauri/binaries/*",
    "dev": "npm run clean:binaries && NODE_ENV=development tsup && bash scripts/rename-binaries.sh",
    "build": "npm run clean:binaries && NODE_ENV=production tsup && node scripts/build-sidecar.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.47",
    "@ai-sdk/deepseek": "^2.0.29",
    "@ai-sdk/openai": "^3.0.33",
    "@hono/node-server": "^1.19.9",
    "ai": "^6.0.99",
    "hono": "^4.12.2",
    "parallel-web": "^0.2.4",
    "undici": "^7.22.0",
    "vercel-minimax-ai-provider": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "@vitest/ui": "^4.0.18",
    "@yao-pkg/pkg": "^6.12.0",
    "dotenv": "^17.2.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
